---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} <strong>Receita Grátis</strong>. Todos os direitos reservados.
	<div class="credits">
		Uma iniciativa de <strong>Anderson Kochanski</strong> | Série <em>Cura Natureza</em>
	</div>
	<div class="social-links">
		<!-- Você pode adicionar links para suas redes sociais aqui -->
	</div>
</footer>

<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
		border-top: 1px solid #e0e0e0;
		margin-top: 2rem;
	}
	.credits {
		margin-top: 1rem;
		font-size: 0.9rem;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: #2e7d32;
	}
</style>
