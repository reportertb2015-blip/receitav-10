---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<div class="logo">
			<a href="/">
				<img src="/logo-receitagratis.webp" alt="Logo Receita Grátis" width="180" height="50" />
			</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Início</HeaderLink>
			<HeaderLink href="/blog">Receitas</HeaderLink>
			<HeaderLink href="/saude-natural">Saúde Natural</HeaderLink>
			<HeaderLink href="/privacidade">Privacidade</HeaderLink>
			<HeaderLink href="/termos">Termos</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
	}
	.logo img {
		display: block;
		height: 50px;
		width: auto;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		padding: 0.8em 0;
	}
	.internal-links {
		display: flex;
		gap: 1em; /* Reduzi um pouco o gap para caber os novos links */
	}
	nav a {
		padding: 0.5em 0.2em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		font-weight: 500;
		font-size: 0.9em; /* Ajuste leve para melhor legibilidade no menu cheio */
	}
	nav a:hover,
	nav a.active {
		text-decoration: none;
		border-bottom-color: #2e7d32;
		color: #2e7d32;
	}
	@media (max-width: 720px) {
		nav {
			flex-direction: column;
			gap: 1em;
		}
		.internal-links {
			flex-wrap: wrap;
			justify-content: center;
		}
	}
</style>
