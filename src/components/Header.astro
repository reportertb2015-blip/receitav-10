---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Início</HeaderLink>
			<HeaderLink href="/blog">Receitas</HeaderLink>
			<HeaderLink href="/sobre">Cura Natureza</HeaderLink>
		</div>
		<div class="social-links">
			<!-- Links para redes sociais se desejar -->
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
	}
	h2 {
		margin: 0;
		font-size: 1.5em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #2e7d32; /* Verde para remeter à natureza */
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		padding: 1em 0;
	}
	.internal-links {
		display: flex;
		gap: 1.5em;
	}
	nav a {
		padding: 0.5em 0.2em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		font-weight: 500;
	}
	nav a:hover,
	nav a.active {
		text-decoration: none;
		border-bottom-color: #2e7d32;
		color: #2e7d32;
	}
</style>
