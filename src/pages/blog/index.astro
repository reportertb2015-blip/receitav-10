---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

// Busca e ordena os posts
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="pt-br">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

		<style>
			/* ===== CONTAINER ===== */
			main {
				max-width: 960px;
				margin: 0 auto;
				padding: 0 1rem;
			}

			/* ===== LISTA ===== */
			ul {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 2rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			ul li {
				border-radius: 16px;
				overflow: hidden;
				transition: transform 0.2s ease;
			}

			ul li:hover {
				transform: translateY(-4px);
			}

			ul li a {
				display: block;
				text-decoration: none;
			}

			ul li img {
				width: 100%;
				height: auto;
				border-radius: 12px;
				margin-bottom: 0.5rem;
				display: block;
			}

			/* ===== TEXTO ===== */
			.title {
				margin: 0.4rem 0;
				font-size: 1.4rem;
				font-weight: bold;
				color: rgb(var(--black));
				line-height: 1.3;
			}

			.date {
				margin: 0;
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}

			ul li a:hover .title,
			ul li a:hover .date {
				color: #2e7d32;
			}

			ul li a:hover img {
				box-shadow: var(--box-shadow);
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<img
										src={post.data.heroImage}
										width={720}
										height={360}
										alt={post.data.title}
										loading="lazy"
									/>

									<h2 class="title">{post.data.title}</h2>

									<time
										class="date"
										datetime={post.data.pubDate.toISOString()}
									>
										{post.data.pubDate.toLocaleDateString('pt-BR', {
											day: '2-digit',
											month: 'short',
											year: 'numeric',
										})}
									</time>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>

		<Footer />
	</body>
</html>
